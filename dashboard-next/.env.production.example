# Production dashboard settings.
# Copy to dashboard-next/.env and set real values before deployment.

ENGINE_API_BASE_URL=http://automation-api:8080
NEXT_PUBLIC_ENGINE_API_BASE_URL=http://localhost:8080
ENGINE_SYNC_STATE_VIEW=default
ENGINE_SYNC_WEBSOCKET_ENABLED=1
ENGINE_SYNC_POLLING_INTERVAL_MS=15000

DASHBOARD_AUTH_ENABLED=1
DASHBOARD_AUTH_SECRET=replace-with-long-random-secret
DASHBOARD_VIEWER_USERNAME=viewer
DASHBOARD_VIEWER_PASSWORD=replace-viewer-password
DASHBOARD_OPERATOR_USERNAME=operator
DASHBOARD_OPERATOR_PASSWORD=replace-operator-password
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=replace-admin-password
